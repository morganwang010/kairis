export const deleteAttendanceRecord = async (id: number) => {
  try {
    console.log('删除考勤记录请求:', id);
    //判断id是否为数字
    if (isNaN(id)) {
      throw new Error('考勤记录ID必须为数字');
    }
    const result = await invoke('delete_attendance_record', { id });
    console.log('删除考勤记录成功:', result);
    return result;
  } catch (error) {
    console.error('删除考勤记录失败:', error);
    throw error;
  }
};

