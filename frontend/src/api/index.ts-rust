// 项目相关API
export const getProjects = async (params?: {
  project_name?: string;
  manager?: string;
  is_active?: boolean;
  page?: number;
  page_size?: number;
}) => {
  try {
    // 转换为HashMap格式
    const queryParams: Record<string, string> = {};
    if (params) {
      if (params.project_name) queryParams.project_name = params.project_name;
      if (params.manager) queryParams.manager = params.manager;
      if (params.is_active !== undefined) queryParams.is_active = params.is_active.toString();
      if (params.page !== undefined) queryParams.page = params.page.toString();
      if (params.page_size !== undefined) queryParams.page_size = params.page_size.toString();
    }
    
    const result = await invoke('get_projects', { query: queryParams });
    // console.log('获取项目列表成功:', result);
    return result as any[];
  } catch (error) {
    console.error('获取项目列表失败:', error);
    throw error;
  }
};
// 创建项目
export const createProject = async (data: any) => {
  try {
    // 构建查询参数
    const queryParams: Record<string, string> = {
      project_name: data.projectName,
      project_abbr: data.projectShortName,
      start_time: data.startTime || '',
      end_time: data.endTime || '',
      manager: data.responsiblePerson || '',
      project_desc: data.description || '',
      status: data.status || 'active'
    };
    
    const response = await invoke('create_project', { query: queryParams });
    return response;
  } catch (error) {
    console.error('创建项目失败:', error);
    throw error;
  }
};
// 更新项目
export const updateProject = async (data: any) => {
  try {
    // 转换为HashMap格式，只传递存在的参数
    const queryParams: Record<string, string> = {
      project_id: data.id,
      project_name: data.projectName,
      project_abbr: data.projectShortName
    };
    
    // 只传递存在的可选参数
    if (data.startTime) queryParams.start_time = data.startTime;
    if (data.endTime) queryParams.end_time = data.endTime;
    if (data.responsiblePerson) queryParams.manager = data.responsiblePerson;
    if (data.clientProjectManager) queryParams.party_a_manager = data.clientProjectManager;
    if (data.clientCompanyName) queryParams.party_a_company = data.clientCompanyName;
    if (data.contactPhone) queryParams.contact_phone = data.contactPhone;
    if (data.description) queryParams.project_desc = data.description;
    
    console.log("project_id {}",data.id)
    const response = await invoke('update_project', { query: queryParams });
    return response;
  } catch (error) {
    console.error('更新项目失败:', error);
    throw error;
  }
};
