// 偶发事件相关API
// 获取偶发事件记录
export const getIncidentRecords = async (params: {
  project_id: string;
  month: string;
  page?: number;
  page_size?: number;
  employee_id?: string;
  name?: string;
}) => {
  try {
    if (!params || !params.project_id || !params.month) {
      throw new Error('缺少必填参数: project_id 和 month');
    }
    
    console.log('here is params:', params);
    
    // 构建查询参数，转换为HashMap格式
    const queryParams: Record<string, string> = {
      project_id: params.project_id,
      month: params.month
    };
    
    if (params.page !== undefined) {
      queryParams.page = params.page.toString();
    }
    if (params.page_size !== undefined) {
      queryParams.page_size = params.page_size.toString();
    }
    if (params.employee_id) {
      queryParams.employee_id = params.employee_id.toString();
    }
    if (params.name) {
      queryParams.name = params.name.toString();
    }
    
    console.log('构建的查询参数:', queryParams);
    const result = await invoke('get_incident_records', {
      query: queryParams
    });
    console.log('获取偶发事件记录成功:', result);
    return result as any;
  } catch (error) {
    console.error('获取偶发事件记录失败:', error);
    throw error;
  }
};

