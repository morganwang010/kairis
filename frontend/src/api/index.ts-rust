    } = {
      from: 'hrms@example.com',
      to: record.email,
      subject: `${record.period || ''} salary slip`,
      body: 'Please find your salary slip attached.',
      attachment: generateSalaryPDF(record),
      employee_id: record.employee_id,
      month: currentMonth,
      project_id: projectId,
    };
    
