// 工资条相关API
export const getSalarySlips = async (params: {
  month: string;
  employee_id?: string | number;
  project_id?: string;
  employee_name?: string;
  page?: number;
  page_size?: number;
}) => {
  try {
    // 转换为HashMap格式
    const queryParams: Record<string, string> = {};
    queryParams.month = params.month;
    if (params.employee_id !== undefined && params.employee_id !== null && params.employee_id !== '') {
      queryParams.employee_id = params.employee_id.toString();
    }
    if (params.project_id) queryParams.project_id = params.project_id;
    if (params.employee_name) queryParams.employee_name = params.employee_name;
    if (params.page !== undefined) queryParams.page = params.page.toString();
    if (params.page_size !== undefined) queryParams.page_size = params.page_size.toString();
    // console.log('工资条查询参数:', queryParams);
    const result = await invoke('get_salary_slips', { query: queryParams });
    return result as { data: any[]; total: number };
  } catch (error) {
    console.error('获取工资条列表失败:', error);
    throw error;
  }
};

export const getSalarySlipDetail = async (id: number) => {
