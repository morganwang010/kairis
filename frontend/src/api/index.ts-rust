// import { invoke } from '@tauri-apps/api/core'
import jsPDF from 'jspdf';
import autoTable from 'jspdf-autotable';

// Extend jsPDF interface to include autoTable methods
declare module 'jspdf' {
  interface jsPDF {
    lastAutoTable: {
      finalY: number;
    };
  }
}

// 获取员工总数（在职员工）
export const getEmployeeCount = async () => {
  try {
    // 使用getEmployees API获取总数，page=1, page_size=1即可获取总数而不需要获取大量数据
    const result = await invoke('get_totalEmployees', {
      query: { page: '1', page_size: '1' }
    });
    const response = result as { total: number };
    return response.total;
  } catch (error) {
    console.error('获取员工总数失败:', error);
    throw error;
  }
};

// 员工相关API
export const getEmployees = async (params?: {
  department?: string;
  position?: string;
  name?: string;
  employee_id?: string;
  project_name?: string;
  location?: string;
  page?: number;
  page_size?: number;
}) => {
  try {
    // 转换为HashMap格式
    const queryParams: Record<string, string> = {};
    if (params) {
      if (params.department) queryParams.department = params.department;
      if (params.position) queryParams.position = params.position;
      if (params.name) queryParams.name = params.name;
      if (params.employee_id) queryParams.employee_id = params.employee_id;
      if (params.project_name) queryParams.project_name = params.project_name;
      if (params.location) queryParams.location = params.location;
      if (params.page !== undefined) queryParams.page = params.page.toString();
      if (params.page_size !== undefined) queryParams.page_size = params.page_size.toString();
    }
    
    const result = await invoke('get_employees', { query: queryParams });
    // 后端返回的是包含data和total的对象，我们需要返回data数组
    const response = result as { data: any[]; total: number };
    return response.data;
  } catch (error) {
    console.error('获取员工列表失败:', error);
    throw error;
  }
};

export const deleteEmployee = async (id: string) => {
  try {
    const result = await invoke('delete_employee', { id });
    console.log('删除员工成功:', result);
    return result;
  } catch (error) {
    console.error('删除员工失败:', error);
    throw error;
  }
};

export const updateEmployee = async (id: string, projectId: string, data: any) => {
  try {
    console.log('开始更新员工数据:', id, projectId, data);
    const result = await invoke('update_employee', { id, projectId, employeeData: data });
    console.log('更新员工成功:', result);
    return result;
  } catch (error) {
    console.error('更新员工失败:', error);
    throw error;
  }
};

// 薪资相关API
export const getSalaries = async (params?: {
  month?: string;
  project_id?: string;
  page?: string;
  page_size?: string;
  employee_id?: string;
  name?: string;
}) => {
  try {
    // 转换为HashMap格式
    const queryParams: Record<string, string> = {};
    if (params) {
      if (params.month) queryParams.month = params.month;
      if (params.project_id) queryParams.project_id = params.project_id;
      if (params.page !== undefined) queryParams.page = params.page.toString();
      if (params.page_size !== undefined) queryParams.page_size = params.page_size.toString();
      if (params.employee_id) queryParams.employee_id = params.employee_id.toString();
      if (params.name) queryParams.name = params.name.toString();
    }
    
    console.log('构建的查询参数:', queryParams);
    const result = await invoke('get_salaries', { query: queryParams });
    return result;
  } catch (error) {
    console.error('获取薪资列表失败:', error);
    throw error;
  }
};

// 更新薪资
export const updateSalary = async (_id: number, data: any) => {
  try {
    // 由于后端目前只有calculate_monthly_salary接口，我们将使用它来处理更新操作
    const response = await invoke('calculate_monthly_salary', {
      month: data.month,
      project_id: data.project_id,
      employee_id: data.employee_id
    });
    return response;
  } catch (error) {
    console.error('更新薪资失败:', error);
    throw error;
  }
};

// 更新薪资计算状态
export const updateSalaryCalculateStatus = async (id: number, checked: number) => {
  try {
    console.log('更新薪资计算状态:', id, checked);
    const response = await invoke('update_calculate_status', {
      id: id.toString(),
      is_calculate: checked.toString(),
      isCalculate: checked.toString(),
    });
    return response;
  } catch (error) {
    console.error('更新薪资计算状态失败:', error);
    throw error;
  }
};

