    // console.log('批量导入偶发事件请求:', records.map(r => r.ot2_wages));
    // console.log('批量导入偶发事件请求:', records.map(r => r.ot3_wages));
    const result = await invoke('import_incident_records', { records });
    console.log('批量导入偶发事件成功:', result);
    return result;
  } catch (error) {
    console.error('批量导入偶发事件失败:', error);
    throw error;
  }
};

